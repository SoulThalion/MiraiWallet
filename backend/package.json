{
  "name": "mirai-wallet-api",
  "version": "1.0.0",
  "description": "Mirai Wallet — REST API with Node.js, Express, Sequelize & JWT",
  "main": "src/server.js",
  "scripts": {
    "dev":              "nodemon src/server.js",
    "start":            "node src/server.js",
    "test":             "vitest run",
    "test:watch":       "vitest",
    "test:coverage":    "vitest run --coverage",
    "lint":             "eslint src --ext .js",
    "db:migrate":       "node src/scripts/migrate.js",
    "db:seed":          "node src/scripts/seed.js"
  },
  "dependencies": {
    "bcryptjs":         "^2.4.3",
    "cors":             "^2.8.5",
    "dotenv":           "^16.4.5",
    "express":          "^4.19.2",
    "express-validator":"^7.1.0",
    "helmet":           "^7.1.0",
    "jsonwebtoken":     "^9.0.2",
    "morgan":           "^1.10.0",
    "mysql2":           "^3.9.7",
    "sequelize":        "^6.37.3",
    "uuid":             "^9.0.1",
    "winston":          "^3.13.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^1.4.0",
    "nodemon":             "^3.1.0",
    "supertest":           "^7.0.0",
    "vitest":              "^1.4.0"
  }
}
