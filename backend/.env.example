# ── App ──────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# 1 → traza /stats/dashboard en consola del servidor (conteo de tx, ingresos, gastos…)
DEBUG_DASHBOARD=0

# ── MySQL ─────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=mirai_wallet
DB_USER=root
DB_PASSWORD=your_password_here
DB_POOL_MAX=10
DB_POOL_MIN=0
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# true  → ALTER TABLE on startup  (dev)
# false → CREATE TABLE IF NOT EXISTS only  (prod)
DB_ALTER=true

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=another_long_random_string
JWT_REFRESH_EXPIRES_IN=30d

# ── Security ──────────────────────────────────────────────
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── CORS ─────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173
